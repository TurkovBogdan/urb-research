# Dev env template. Copy to `.env` in the project root and fill the CHANGE_ME
# secrets. Run from the root as `uv run python src/app.py …`.

# ─── App: identity ────────────────────────────────────────────────────────────
APP_ENV=dev
APP_LOG_LEVEL=INFO

# ─── Server: HTTP transport ───────────────────────────────────────────────────
# bind HTTP zones (internal/external/webhook). dev = true. CLI --backend overrides.
SERVER_ENABLED=true
SERVER_HOST=127.0.0.1
SERVER_PORT=12200
# hot-reload the server on src/ changes: uvicorn --reload + file watch. dev only;
# incompatible with SERVER_PROCESSES>1. CLI: --hot-reload/--no-hot-reload.
SERVER_HOT_RELOAD=true
# uvicorn processes (NOT the background worker — HTTP scaling). 1 = single process;
# >1 spreads across cores (then migrations via `src/app.py migrate` only, scheduler
# in the worker process). Ignored when SERVER_HOT_RELOAD=true. CLI: --processes N.
SERVER_PROCESSES=1
# Vite dev-server port — only for dev CORS + Vite proxy target. Empty = prod.
SERVER_VITE_PORT=12100
# Allowed Host headers for mounted MCP servers (CSV, DNS-rebinding guard). Empty in
# dev = no check (localhost). In prod set your public host(s).
MCP_ALLOWED_HOSTS=
# Static bearer token guarding the MCP surface (/mcp/<code>). Empty = allow-all (no
# check). Auto-generated on first launch when no .env exists; the /mcp-servers page
# embeds it into the connection config. Set your own to rotate.
MCP_TOKEN=

# MCP stdio shim (`--mcp-stdio`): the client spawns us over stdio; we lazily boot
# the backend and bridge tool calls to its /mcp/<code>. Nothing runs idle; the
# backend outlives the shim (stop it manually).
# Open the system browser on the home page once the backend is booted.
MCP_STDIO_OPEN_BROWSER=true
# Boot the scheduler/worker alongside the backend (research/search are synchronous).
MCP_STDIO_START_WORKER=false
# Seconds to wait for backend readiness (/internal/health) after spawn.
MCP_STDIO_BOOT_TIMEOUT=30
# Proxied MCP server code. Empty = the sole server mounted by modules.
MCP_STDIO_CODE=

# ─── Dev: test setup ──────────────────────────────────────────────────────────
# Tests run on in-memory SQLite — no external Postgres pool needed (see tests/README.md).
# Heavy Alembic-migration tests (Postgres-only) opt in via a real DB DSN:
# TEST_PG_DSN=postgresql://user:pass@host:port/dbname

# Real account for live/browser (e2e) login — NOT used by the self-contained pure/db suite.
TEST_USER_EMAIL=CHANGE_ME
TEST_USER_PASSWORD=CHANGE_ME

# ─── Database: provider ───────────────────────────────────────────────────────
# postgres — основа (pgvector); sqlite — zero-install, без сервера (один файл)
DB_PROVIDER=postgres
# SQLite file (only when DB_PROVIDER=sqlite); empty = <runtime_root>/app.sqlite3
# DB_PATH=

# ─── Database: connection (postgres only) ─────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=core_semaphore_dev
DB_USER=core_semaphore_dev
DB_PASSWORD=CHANGE_ME
# log SQL queries
DB_ECHO=false

# ─── Database: TLS ────────────────────────────────────────────────────────────
DB_SSL=false
# path to CA from app root (required when DB_SSL=true)
DB_CERT=
# client cert for mutual TLS — set as a pair
DB_CLIENT_CERT=
DB_CLIENT_KEY=

# ─── Database: pool ───────────────────────────────────────────────────────────
# connection establishment timeout, sec
DB_CONNECT_TIMEOUT=10
# persistent connections in the pool
DB_POOL_SIZE=8
# extra connections for bursts (closed afterwards)
DB_MAX_OVERFLOW=10
# recycle a connection every N sec (< NAT timeout)
DB_POOL_RECYCLE=1800
# how long to wait for a pooled connection, sec
DB_POOL_TIMEOUT=30

# ─── Database: performance ────────────────────────────────────────────────────
# limit per single query, sec; 0 = no limit (safe for heavy DDL)
DB_COMMAND_TIMEOUT=0
# liveness check before checkout (+1 RTT, guards against dropped connections)
DB_POOL_PRE_PING=true
# keepalive toward PG, idle sec; 0 = PG default
DB_TCP_KEEPALIVES_IDLE=60

# ─── Database: migrations ─────────────────────────────────────────────────────
# apply Alembic upgrade on startup. dev-watch (uvicorn --reload) can keep it true
# (idempotent), but the run-configs set it false + apply via `src/app.py migrate`.
DB_AUTO_MIGRATE=true

# ─── Worker: scheduler + tasks ────────────────────────────────────────────────
# run the scheduler + tasks in this process; dev = true (one process runs web +
# tasks). prod-web = false (background lives in a dedicated worker process).
# CLI --worker overrides (flag > env).
WORKER_ENABLED=true
# scope: CSV of module names whose tasks this process runs; empty = all. CLI: --worker-module
WORKER_MODULES=
# tick interval — how often the registry is checked for due tasks, sec
WORKER_TICK_SECONDS=5
# max tasks running at once; keep <= DB_POOL_SIZE + DB_MAX_OVERFLOW
WORKER_MAX_CONCURRENT_RUNS=1

# ─── Module: llm_providers ────────────────────────────────────────────────────
LLM_PROVIDERS_ANTHROPIC_API_KEY=CHANGE_ME
LLM_PROVIDERS_OPENAI_API_KEY=CHANGE_ME
LLM_PROVIDERS_XAI_API_KEY=CHANGE_ME
LLM_PROVIDERS_OPENROUTER_API_KEY=CHANGE_ME
# Optional: OpenRouter base URL override (defaults to the public endpoint).
LLM_PROVIDERS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_PROVIDERS_LMSTUDIO_IP=127.0.0.1
LLM_PROVIDERS_LMSTUDIO_PORT=1234
LLM_PROVIDERS_LMSTUDIO_TOKEN=
# Optional: full base URL override (domain + https). When set, overrides IP/PORT.
# e.g. https://local.uroboros.tech
LLM_PROVIDERS_LMSTUDIO_BASE_URL=
LLM_PROVIDERS_REQUEST_TIMEOUT_SEC=60

# ─── Module: intercom ─────────────────────────────────────────────────────────
INTERCOM_ACCESS_TOKEN=CHANGE_ME
INTERCOM_APP_ID=CHANGE_ME

# ─── Module: twenty ───────────────────────────────────────────────────────────
TWENTY_BASE_URL=CHANGE_ME
TWENTY_API_KEY=CHANGE_ME

# ─── Module: mail_sync ────────────────────────────────────────────────────────
# Gmail service-account JSON key (domain-wide delegation). Path relative to the
# runtime root (runtime/<env>/); keep the key under runtime/<env>/secrets/ (chmod 600).
MAIL_SYNC_GMAIL_SERVICE_ACCOUNT_FILE=secrets/gmail_service_account_file.json
# Gmail import tuning (optional; defaults shown). Batch = messages.get per HTTP
# round-trip; concurrency = parallel batch workers per mailbox (per-account quota
# caps the useful total at ~5).
# MAIL_SYNC_GMAIL_BATCH_SIZE=25
# MAIL_SYNC_GMAIL_CONCURRENCY=5

# ─── Module: core_storage ─────────────────────────────────────────────────────
# ceiling for any stored file, MB (optional; default shown). Checked on the
# original (pre-validator) bytes in the admission pipeline.
# CORE_STORAGE_MAX_FILE_SIZE_MB=128
# raster image bounding box, px (optional; defaults shown). Larger images are
# proportionally downscaled to fit during processing.
# CORE_STORAGE_IMAGE_MAX_WIDTH=4096
# CORE_STORAGE_IMAGE_MAX_HEIGHT=4096
# OOXML (docx/xlsx) anti-bomb limits (optional; defaults shown), checked on the zip
# central directory before parsing.
# CORE_STORAGE_OOXML_MAX_UNCOMPRESSED_MB=512
# CORE_STORAGE_OOXML_MAX_COMPRESSION_RATIO=200
# CORE_STORAGE_OOXML_MAX_ENTRIES=8192

# ─── Module: conversation_insights ────────────────────────────────────────────
# chat_priority patience window (days): while a client's-court thread (awaiting_client
# / on_hold) has been silent fewer days than this, the wait is "healthy" → near-zero
# priority. Past it the deal is "slipping" → priority climbs, amplified by deal value.
CONVERSATION_INSIGHTS_PRIORITY_PATIENCE_DAYS=21

# ─── Module: core_users ───────────────────────────────────────────────────────
# admin seeded by migration cu01_init. Generate the hash with:
#   uv run python src/app_hash_password.py   (paste output below; empty = no admin seeded)
CORE_USERS_ADMIN_EMAIL=admin@CHANGE_ME
CORE_USERS_ADMIN_PASSWORD_HASH=CHANGE_ME
# session TTL (sec): absolute cap + idle (0 = no idle timeout)
CORE_USERS_SESSION_LIFETIME=14400
CORE_USERS_SESSION_IDLE=900
# cookie: dev over plain HTTP → secure=false; prod behind TLS → true
CORE_USERS_SESSION_COOKIE_NAME=sid
CORE_USERS_SESSION_COOKIE_SECURE=false
CORE_USERS_SESSION_COOKIE_SAMESITE=strict
# access tokens (mcp/api): TTL in days + HMAC key (pepper). Set a unique secret here
# (a DB-only leak can't forge tokens without it). Rotating the pepper invalidates all
# existing tokens.
CORE_USERS_TOKEN_LIFETIME_DAYS=14
CORE_USERS_TOKEN_PEPPER=CHANGE_ME

# web_search provider + tokens (Tavily/Firecrawl) are runtime settings in the DB
# (page /core/settings, secret fields), not .env.
