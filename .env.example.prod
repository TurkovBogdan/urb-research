# Production instance config — read by Config (pydantic-settings) from `.env`
# next to the app root. BOTH processes read this file; the worker process runs
# the same `src/app.py` with `--worker --no-backend` and overrides its knobs via CLI
# (flag > env): `--worker-module` / `--worker-tick-seconds` / `--worker-max-concurrent`.
# This file is the SERVER role's config.

# ─── App: identity ────────────────────────────────────────────────────────────
APP_ENV=prod
APP_LOG_LEVEL=INFO

# ─── Server: HTTP transport ───────────────────────────────────────────────────
# this is the web process → serve the HTTP zones. (Worker is a separate process.)
SERVER_ENABLED=true
# 0.0.0.0 so the container is reachable from the nginx container over the compose
# network. TLS termination + public exposure is the reverse proxy's job.
SERVER_HOST=0.0.0.0
SERVER_PORT=13410
# hot-reload is a dev-only convenience — keep false in prod.
SERVER_HOT_RELOAD=false
# uvicorn processes (HTTP scaling, NOT the background worker). >1 spreads across
# cores, but keep DB_AUTO_MIGRATE=false (migrate via `src/app.py migrate upgrade`).
SERVER_PROCESSES=1
# Vite dev-server port — dev-only (CORS). Leave empty in prod: nginx serves the SPA.
SERVER_VITE_PORT=
# DEBUG-only per-request delay (ms) on the internal zone; keep 0 in prod.
SERVER_DEBUG_DELAY_MS=0

# ─── MCP: modules-as-MCP-servers surface (zone /mcp) ──────────────────────────
# Allowed Host headers for the mounted MCP servers (CSV) — DNS-rebinding guard at
# the ASGI layer (TrustedHostMiddleware). In prod behind nginx set your public
# host(s); empty disables the check (relies on nginx server_name filtering).
MCP_ALLOWED_HOSTS=
# Static bearer token guarding the MCP surface (/mcp/<code>). Empty = allow-all.
# Auto-generated on first launch when no .env exists; the /mcp-servers page embeds
# it into the connection config. In prod set a unique secret here.
MCP_TOKEN=

# MCP stdio shim (`--mcp-stdio`) — local wake-on-demand model: the client spawns us
# over stdio, we lazily boot the backend and bridge to its /mcp/<code>. Primarily a
# local convenience; a remote prod deploy usually keeps the HTTP backend running.
MCP_STDIO_OPEN_BROWSER=true
MCP_STDIO_START_WORKER=false
MCP_STDIO_BOOT_TIMEOUT=30
MCP_STDIO_CODE=

# ─── Database: provider ───────────────────────────────────────────────────────
# postgres — основа (pgvector); sqlite — zero-install, без сервера (один файл)
DB_PROVIDER=postgres
# SQLite file (only when DB_PROVIDER=sqlite); empty = <runtime_root>/app.sqlite3
# DB_PATH=

# ─── Database: connection (postgres only) ─────────────────────────────────────
DB_HOST=external-database
DB_PORT=5432
DB_NAME=semaphore_core
DB_USER=semaphore_core
DB_PASSWORD=CHANGE_ME
# log SQL queries
DB_ECHO=false

# ─── Database: TLS ────────────────────────────────────────────────────────────
# No TLS in prod (trusted network between the app and the DB). If you ever point
# at a remote/untrusted PG, set DB_SSL=true and provide DB_CERT (verify-full).
DB_SSL=false
# path to CA from app root (required only when DB_SSL=true)
DB_CERT=
# client cert for mutual TLS — set as a pair, or leave both empty
DB_CLIENT_CERT=
DB_CLIENT_KEY=

# ─── Database: pool ───────────────────────────────────────────────────────────
# connection establishment timeout, sec
DB_CONNECT_TIMEOUT=10
# persistent connections in the pool
DB_POOL_SIZE=8
# extra connections for bursts (closed afterwards)
DB_MAX_OVERFLOW=10
# recycle a connection every N sec (< NAT timeout)
DB_POOL_RECYCLE=1800
# how long to wait for a pooled connection, sec
DB_POOL_TIMEOUT=30

# ─── Database: performance ────────────────────────────────────────────────────
# limit per single query, sec; 0 = no limit (safe for heavy DDL)
DB_COMMAND_TIMEOUT=0
# liveness check before checkout (+1 RTT, guards against dropped connections)
DB_POOL_PRE_PING=true
# keepalive toward PG, idle sec; 0 = PG default
DB_TCP_KEEPALIVES_IDLE=60

# ─── Database: migrations ─────────────────────────────────────────────────────
# prod: keep false and run `src/app.py migrate upgrade` as a separate deploy step
# (avoids a half-applied migration on multi-process / reload restarts).
DB_AUTO_MIGRATE=false

# ─── Worker: scheduler + tasks ────────────────────────────────────────────────
# SERVER role → false: the scheduler runs in the dedicated worker process, NOT
# here. That process runs the same binary with `--worker --no-backend`; the knobs
# below are its defaults and are overridable per-process via the matching CLI flags.
WORKER_ENABLED=false
# scope: CSV of module names whose tasks the worker runs; empty = all. CLI: --worker-module
WORKER_MODULES=
# tick interval — how often the registry is checked for due tasks, sec. CLI: --worker-tick-seconds
WORKER_TICK_SECONDS=5
# max tasks running at once; keep <= DB_POOL_SIZE + DB_MAX_OVERFLOW. CLI: --worker-max-concurrent
WORKER_MAX_CONCURRENT_RUNS=10

# ─── Module: llm_providers ────────────────────────────────────────────────────
LLM_PROVIDERS_ANTHROPIC_API_KEY=CHANGE_ME
LLM_PROVIDERS_OPENAI_API_KEY=CHANGE_ME
LLM_PROVIDERS_XAI_API_KEY=CHANGE_ME
LLM_PROVIDERS_OPENROUTER_API_KEY=CHANGE_ME
# Optional: OpenRouter base URL override (defaults to the public endpoint).
LLM_PROVIDERS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_PROVIDERS_LMSTUDIO_IP=127.0.0.1
LLM_PROVIDERS_LMSTUDIO_PORT=1234
LLM_PROVIDERS_LMSTUDIO_TOKEN=
# Optional: full base URL override (domain + https). When set, overrides IP/PORT.
# e.g. https://local.uroboros.tech
LLM_PROVIDERS_LMSTUDIO_BASE_URL=
LLM_PROVIDERS_REQUEST_TIMEOUT_SEC=60

# ─── Module: intercom ─────────────────────────────────────────────────────────
INTERCOM_ACCESS_TOKEN=CHANGE_ME
INTERCOM_APP_ID=CHANGE_ME

# ─── Module: twenty ───────────────────────────────────────────────────────────
TWENTY_BASE_URL=CHANGE_ME
TWENTY_API_KEY=CHANGE_ME

# ─── Module: mail_sync ────────────────────────────────────────────────────────
# Gmail service-account JSON key (domain-wide delegation). Path relative to the
# runtime root (runtime/prod/); keep the key under runtime/prod/secrets/ (chmod 600).
MAIL_SYNC_GMAIL_SERVICE_ACCOUNT_FILE=secrets/gmail_service_account_file.json
# Gmail import tuning (optional; defaults shown). Batch = messages.get per HTTP
# round-trip; concurrency = parallel batch workers per mailbox (per-account quota
# caps the useful total at ~5).
# MAIL_SYNC_GMAIL_BATCH_SIZE=25
# MAIL_SYNC_GMAIL_CONCURRENCY=5

# ─── Module: core_storage ─────────────────────────────────────────────────────
# ceiling for any stored file, MB (optional; default shown). Checked on the
# original (pre-validator) bytes in the admission pipeline.
# CORE_STORAGE_MAX_FILE_SIZE_MB=128
# raster image bounding box, px (optional; defaults shown). Larger images are
# proportionally downscaled to fit during processing.
# CORE_STORAGE_IMAGE_MAX_WIDTH=4096
# CORE_STORAGE_IMAGE_MAX_HEIGHT=4096
# OOXML (docx/xlsx) anti-bomb limits (optional; defaults shown), checked on the zip
# central directory before parsing.
# CORE_STORAGE_OOXML_MAX_UNCOMPRESSED_MB=512
# CORE_STORAGE_OOXML_MAX_COMPRESSION_RATIO=200
# CORE_STORAGE_OOXML_MAX_ENTRIES=8192

# ─── Module: conversation_insights ────────────────────────────────────────────
# chat_priority patience window (days): while a client's-court thread (awaiting_client
# / on_hold) has been silent fewer days than this, the wait is "healthy" → near-zero
# priority. Past it the deal is "slipping" → priority climbs, amplified by deal value.
CONVERSATION_INSIGHTS_PRIORITY_PATIENCE_DAYS=21

# ─── Module: core_users ───────────────────────────────────────────────────────
# admin seeded by migration cu01_init. Generate the hash on the host with:
#   uv run python src/app_hash_password.py   (empty hash = no admin seeded)
CORE_USERS_ADMIN_EMAIL=admin@CHANGE_ME
CORE_USERS_ADMIN_PASSWORD_HASH=CHANGE_ME
# session TTL (sec): absolute cap + idle (0 = no idle timeout)
CORE_USERS_SESSION_LIFETIME=14400
CORE_USERS_SESSION_IDLE=900
# cookie: prod is served behind TLS → Secure=true (browser only sends it over HTTPS)
CORE_USERS_SESSION_COOKIE_NAME=sid
CORE_USERS_SESSION_COOKIE_SECURE=true
CORE_USERS_SESSION_COOKIE_SAMESITE=strict
# access tokens (mcp/api): TTL in days + HMAC key (pepper). MUST set a unique secret
# pepper here (NOT the shared default) — a DB-only leak can't forge tokens without it.
# Rotating the pepper invalidates all existing tokens.
CORE_USERS_TOKEN_LIFETIME_DAYS=14
CORE_USERS_TOKEN_PEPPER=CHANGE_ME

# web_search provider + tokens (Tavily/Firecrawl) are runtime settings in the DB
# (page /core/settings, secret fields), not .env.
